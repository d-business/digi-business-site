---
// Save as: src/pages/services.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Foundation',
    price: '£3,500/mo',
    description: 'For businesses ready to establish a serious digital presence',
    features: [
      'Technical SEO audit and fixes',
      'Monthly content strategy',
      'AI-powered monthly report',
      'Monthly strategy call',
    ],
    featured: false,
  },
  {
    name: 'Growth',
    price: '£7,000/mo',
    description: 'For businesses serious about market leadership',
    features: [
      'Everything in Foundation',
      'Google Ads management',
      'Meta Ads management',
      'Email marketing',
      'Fortnightly strategy calls',
    ],
    featured: true,
  },
  {
    name: 'Partner',
    price: '£10,000/mo',
    description: 'Full-service digital growth partnership',
    features: [
      'Everything in Growth',
      'Operational automation',
      'Custom AI tooling',
      'Weekly calls and reporting',
      'Priority response',
    ],
    featured: false,
  },
];
---

<BaseLayout
  title="Digital Marketing Services for Outdoor Leisure Businesses | Digital Business"
  description="Digital marketing retainers from £3,500/month for outdoor leisure businesses. SEO, Google Ads, Meta Ads, email and AI-powered reporting."
>
  <section class="container section-header">
    <p class="eyebrow">What we offer</p>
    <h1>Services built for outdoor leisure businesses</h1>
  </section>

  <section class="container">
    <p class="eyebrow">Retainer packages</p>
    <h2>Choose the right level of support</h2>
    <p>
      All packages include dedicated account management, monthly AI-powered reporting, and access to our full team. No lock-in contracts after the initial 3 months.
    </p>

    <div class="tiers">
      {tiers.map((tier) => (
        <div class:list={['tier-card', { 'tier-card--featured': tier.featured }]}>
          {tier.featured && <p class="tier-card__badge">Most popular</p>}
          <h3>{tier.name}</h3>
          <p class="tier-card__price">{tier.price}</p>
          <p class="tier-card__description">{tier.description}</p>
          <ul>
            {tier.features.map((feature) => (
              <li>+ {feature}</li>
            ))}
          </ul>
          <a href="/contact" class="button">Enquire</a>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .section-header {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-md);
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-md);
    margin: var(--space-lg) 0 var(--space-xl);
  }

  .tier-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
  }

  .tier-card--featured {
    border-color: var(--color-accent);
    border-width: 2px;
  }

  .tier-card__badge {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .tier-card__price {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-forest);
  }

  .tier-card__description {
    color: var(--color-text-muted);
  }

  .tier-card ul {
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0;
    flex-grow: 1;
  }

  .tier-card li {
    padding: 0.3rem 0;
  }
</style>
