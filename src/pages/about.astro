---
export const prerender = true;
// Save as: src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  {
    name: 'Will Hawkins',
    role: 'Founder — SEO, Strategy and Technology',
    bio: '17 years building digital presence for outdoor leisure businesses. Owns technical SEO, overall strategy, and the technology infrastructure that powers our AI-driven reporting and automation.',
  },
  {
    name: 'Lynne Cullen',
    role: 'Partner — SEO, Paid Media, Email and Social',
    bio: 'Specialist in PPC campaign management across Google and Meta, email marketing strategy, and social media. Brings precision and performance focus to every campaign she manages.',
  },
];
---

<BaseLayout
  title="About Digital Business | 17 Years in Outdoor Leisure Digital Marketing"
  description="Digital Business is a specialist digital marketing agency with 17 years of exclusive focus on the outdoor leisure vehicle market. Founded by Will Hawkins."
>
  <section class="hero">
    <div class="container hero__inner">
      <p class="eyebrow eyebrow--hero">About us</p>
      <h1 class="hero__heading">A specialist agency built on deep market knowledge</h1>
    </div>
  </section>

  <section class="container story-team">
    <div class="story-team__story">
      <p class="eyebrow">Our story</p>
      <h2>Why we chose one market and stuck with it</h2>
      <p>
        Digital Business was founded on a simple premise: that deep niche expertise delivers better results than broad generalism. While other agencies chased every client in every sector, we chose to go deep in one.
      </p>
      <p>
        After 17 years working exclusively in the outdoor leisure vehicle market, we understand this sector at a level no generalist agency can match. We know the brands, the buyers, the seasonality, the competition, and the margins.
      </p>
      <p>
        That knowledge is built from years of running campaigns, analysing data, and delivering results for businesses selling caravans, motorhomes, campervans, and accessories across the UK.
      </p>
    </div>
    <div class="story-team__team">
      <p class="eyebrow">The team</p>
      {team.map((person, index) => (
        <div class:list={['team-member', { 'team-member--divider': index > 0 }]}>
          <h3>{person.name}</h3>
          <p class="team-member__role">{person.role}</p>
          <p>{person.bio}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .hero {
    background-color: var(--color-forest);
  }

  .hero__inner {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
    max-width: 800px;
  }

  .eyebrow--hero {
    color: var(--color-moss);
  }

  .hero__heading {
    color: var(--color-stone);
  }

  .story-team {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .team-member {
    margin-bottom: var(--space-md);
  }

  .team-member--divider {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
  }

  .team-member__role {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.9rem;
  }

  @media (max-width: 720px) {
    .story-team {
      grid-template-columns: 1fr;
    }
  }
</style>
