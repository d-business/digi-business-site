---
export const prerender = true;
// Save as: src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { value: '17', label: 'Years in the outdoor leisure market' },
  { value: '1', label: 'Niche. Deep expertise, not wide mediocrity.' },
  { value: 'AI', label: 'Powered reporting and automation' },
  { value: '£1m+', label: 'Target client turnover range' },
];

const services = [
  {
    title: 'SEO and Content',
    description: 'Technical SEO, content strategy, and AI search optimisation built for the outdoor leisure buyer journey.',
  },
  {
    title: 'Paid Media',
    description: 'Google Ads and Meta campaigns managed by specialists who understand your audience and your margins.',
  },
  {
    title: 'Reporting and Automation',
    description: 'AI-powered monthly reporting and business automation so you spend less time on admin and more on growth.',
  },
];
---

<BaseLayout
  title="Digital Business | Outdoor Leisure Digital Marketing Specialists"
  description="Specialist digital marketing for outdoor leisure businesses. 17 years in caravans, motorhomes and campervans. SEO, Ads and automation."
>
  <section class="hero">
    <div class="container hero__inner">
      <p class="eyebrow eyebrow--hero">Outdoor Leisure Vehicle Market</p>
      <h1 class="hero__heading">Digital growth for outdoor leisure businesses that mean business</h1>
      <p class="hero__lead">
        17 years. One niche. We know your market, your customers, and what actually moves the needle. No generalists. No guesswork.
      </p>
      <div class="hero__actions">
        <a href="/contact" class="button">Start the conversation</a>
        <a href="/services" class="button button--outline button--outline-light">See our services</a>
      </div>
    </div>
  </section>

  <section class="section container why">
    <div class="why__text">
      <p class="eyebrow">Why Digital Business</p>
      <h2>17 years. One market. Unmatched expertise.</h2>
      <p>
        Most digital agencies claim they can work with any business. We chose differently. For nearly two decades we have worked exclusively in the outdoor leisure vehicle sector.
      </p>
      <p>
        That depth means we understand the buying cycles, seasonal patterns, audience psychology, and competitive landscape better than any generalist agency ever could.
      </p>
      <a href="/about" class="button button--outline-dark">About us</a>
    </div>
    <div class="why__stats">
      {stats.map((stat, index) => (
        <div class:list={['stat-card', { 'stat-card--highlight': index === stats.length - 1 }]}>
          <p class="stat-card__value">{stat.value}</p>
          <p class="stat-card__label">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section container">
    <p class="eyebrow">What we do</p>
    <h2>Full-service digital marketing built for your market</h2>
    <div class="services-grid">
      {services.map((service) => (
        <div class="service-card">
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </div>
      ))}
    </div>
    <a href="/services">See all services and pricing</a>
  </section>

  <section class="section section--cta container">
    <p class="eyebrow">Ready to grow?</p>
    <h2>Let's talk about your business</h2>
    <p>
      We work with a small number of outdoor leisure businesses on a retainer basis. If you are turning over £1m to £10m and want a genuine digital growth partner, we would like to hear from you.
    </p>
    <a href="/contact" class="button">Get in touch</a>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .hero {
    background-color: var(--color-forest);
  }

  .hero__inner {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
    max-width: 800px;
  }

  .eyebrow--hero {
    color: var(--color-moss);
  }

  .hero__heading {
    color: var(--color-stone);
  }

  .hero__lead {
    font-size: 1.15rem;
    max-width: 640px;
    color: var(--color-stone);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }

  .section {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .why {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .why__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .stat-card {
    background-color: var(--color-surface);
    border-radius: var(--radius);
    padding: var(--space-md);
  }

  .stat-card__value {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-forest);
    margin: 0 0 0.25rem;
  }

  .stat-card__label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .stat-card--highlight {
    background-color: var(--color-forest);
  }

  .stat-card--highlight .stat-card__value,
  .stat-card--highlight .stat-card__label {
    color: var(--color-moss);
  }

  @media (max-width: 720px) {
    .why {
      grid-template-columns: 1fr;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-md);
    margin: var(--space-md) 0;
  }

  .service-card {
    background-color: var(--color-surface);
    border-radius: var(--radius);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
  }

  .section--cta {
    text-align: center;
    background-color: var(--color-forest);
    color: var(--color-stone);
    border-radius: var(--radius);
    padding: var(--space-xl) var(--space-md);
  }

  .section--cta h2 {
    color: var(--color-stone);
  }

  .button--outline {
    background-color: transparent;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }

  .button--outline:hover {
    background-color: var(--color-accent);
    color: #ffffff;
  }

  .button--outline-light {
    color: var(--color-stone);
    border-color: var(--color-stone);
  }

  .button--outline-light:hover {
    background-color: var(--color-stone);
    color: var(--color-forest);
  }

  .button--outline-dark {
    background-color: transparent;
    color: var(--color-forest);
    border: 2px solid var(--color-forest);
  }

  .button--outline-dark:hover {
    background-color: var(--color-forest);
    color: #ffffff;
  }
</style>
